# LaunchBusiness AI — Environment Variables Reference
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to:
#   Local dev:  backend/.env
#   Production: /root/secrets/swiftpack.env
#
# NEVER commit a file containing real values.
# Generate secrets: python -c "import secrets; print(secrets.token_hex(32))"
# ─────────────────────────────────────────────────────────────────────────────

# ── MongoDB (REQUIRED) ────────────────────────────────────────────────────────
# Docker uses service name "mongo" as hostname in production
MONGODB_URL=mongodb://mongo:27017
DB_NAME=launchbusinessai_db

# ── JWT & Admin (REQUIRED) ───────────────────────────────────────────────────
# JWT_SECRET: min 32 chars — used to sign all user tokens
# ADMIN_SECRET: used by JARVIS intelligence endpoint (X-Admin-Key header)
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_32_CHARS
ADMIN_SECRET=REPLACE_WITH_STRONG_ADMIN_SECRET

# ── CORS & URLs (REQUIRED) ───────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://launchbusinessai.com,https://www.launchbusinessai.com
BACKEND_URL=https://launchbusinessai.com
FRONTEND_URL=https://launchbusinessai.com

# ── Google Gemini AI (REQUIRED) ──────────────────────────────────────────────
# aistudio.google.com → Get API key
GEMINI_API_KEY=REPLACE_WITH_GEMINI_API_KEY

# ── Google OAuth (optional — enables Sign in with Google) ────────────────────
# console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client
# Authorized redirect URI: https://launchbusinessai.com/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── AI Fallback chain (optional) ─────────────────────────────────────────────
# If Gemini fails, OpenRouter is tried before falling back to a built-in template.
OPENROUTER_API_KEY=

# ── Helicone — AI cost + latency tracking (optional) ─────────────────────────
# helicone.ai → Settings → API Keys
# When set, all Gemini calls route through Helicone gateway for observability.
HELICONE_API_KEY=
HELICONE_HOST=https://gateway.helicone.ai

# ── Email — Brevo transactional (optional) ───────────────────────────────────
# app.brevo.com → SMTP & API → API Keys
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply@launchbusinessai.com
BREVO_SENDER_NAME=LaunchBusiness AI

# ── Stripe (optional — activate when billing goes live) ──────────────────────
# dashboard.stripe.com → Developers → API keys
# Create 3 recurring products in Stripe Dashboard, paste the price IDs here:
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=      # $19/month
STRIPE_PRO_PRICE_ID=          # $49/month
STRIPE_AGENCY_PRICE_ID=       # $149/month

# ── Modal GPU — Pro/Agency video + talking head (optional) ───────────────────
# modal.com → Settings → API Tokens
# Deploy once:
#   modal deploy backend/modal_video.py
#   modal deploy backend/modal_sadtalker.py
# LTX-Video: ~$0.44/video on A100 | SadTalker: ~$0.10/video on A10G
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
MODAL_APP_NAME=launchbusiness-ltx-video
MODAL_SADTALKER_APP=launchbusiness-sadtalker

# ── Ideogram AI — logo AI concepts (optional) ────────────────────────────────
# ideogram.ai → API → Create token
# Without this the Logo Creator still works with Pillow templates;
# only the "AI Concepts" tab requires it.
IDEOGRAM_API_KEY=

# ── Sentry — error tracking (optional) ───────────────────────────────────────
# sentry.io → Project → Settings → Client Keys (DSN)
SENTRY_DSN=
SENTRY_RELEASE=launchbusiness@1.0.0

# ── Runtime ───────────────────────────────────────────────────────────────────
# "production" | "development"
ENVIRONMENT=production

# ── Server / Deployment ───────────────────────────────────────────────────────
# Contabo VPS — server runs as root
SERVER_HOST=REPLACE_WITH_CONTABO_VPS_IP
DOMAIN=launchbusinessai.com

# ── Music Beds (background audio for videos) ──────────────────────────────────
# No env var needed — drop royalty-free .mp3 files into backend/assets/music_beds/
# Sources: pixabay.com/music | mixkit.co/free-music | ccmixter.org
# Empty folder = feature silently skipped (no error thrown)
