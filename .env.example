# LaunchBusiness AI — Environment Variables Reference
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to:
#   Local dev:  backend/.env
#   Production: /root/secrets/swiftpack.env
#
# NEVER commit a file containing real values.
# Generate secrets: python -c "import secrets; print(secrets.token_hex(32))"
# ─────────────────────────────────────────────────────────────────────────────

# ── MongoDB (REQUIRED) ────────────────────────────────────────────────────────
# Docker uses service name "mongo" as hostname in production.
# Local dev: mongodb://localhost:27017
MONGODB_URL=mongodb://mongo:27017
DB_NAME=launchbusinessai_db

# ── JWT & Admin (REQUIRED) ───────────────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_32_CHARS
ADMIN_SECRET=REPLACE_WITH_STRONG_ADMIN_SECRET

# ── CORS & URLs (REQUIRED) ───────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://launchbusinessai.com,https://www.launchbusinessai.com
BACKEND_URL=https://launchbusinessai.com
FRONTEND_URL=https://launchbusinessai.com

# ── Google Gemini AI (REQUIRED) ──────────────────────────────────────────────
# aistudio.google.com → Get API key
# Used for: scripts, Tutorial Studio narration, logo AI concepts, legal docs
GEMINI_API_KEY=REPLACE_WITH_GEMINI_API_KEY

# ── Google Safe Browsing (REQUIRED for URL safety) ───────────────────────────
# Blocks malware, phishing, social engineering URLs before scraping.
# Free: 10,000 checks/day.
#
# Setup (5 minutes):
#   1. console.cloud.google.com → select or create a project
#   2. APIs & Services → Library → search "Safe Browsing API" → Enable
#   3. APIs & Services → Credentials → Create Credentials → API Key
#   4. Paste the key here
#
# Without this: hostname + content keyword checks still run, but phishing
# sites with clean-looking domain names slip through.
GOOGLE_SAFE_BROWSING_API_KEY=

# ── Pexels — real video B-roll (optional but recommended) ────────────────────
# Adds real stock video footage to the Magic Button video pipeline.
# Without it: Pillow design slides only (still good). With it: real footage mix.
#
# Setup (2 minutes, free):
#   1. pexels.com/api → sign up → API key on dashboard instantly
#   Free quota: 200 req/hour, 20,000/month. No credit card.
PEXELS_API_KEY=

# ── Google OAuth (optional — enables Sign in with Google) ────────────────────
# console.cloud.google.com → Credentials → OAuth 2.0 Client
# Authorized redirect URI: https://launchbusinessai.com/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── AI Fallback chain (optional) ─────────────────────────────────────────────
# If Gemini fails, OpenRouter is tried before falling back to built-in templates.
# openrouter.ai → Settings → API Keys
OPENROUTER_API_KEY=

# ── Helicone — AI cost + latency tracking (optional) ─────────────────────────
# helicone.ai → Settings → API Keys
HELICONE_API_KEY=
HELICONE_HOST=https://gateway.helicone.ai

# ── Email — Brevo transactional (optional) ───────────────────────────────────
# app.brevo.com → SMTP & API → API Keys
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply@launchbusinessai.com
BREVO_SENDER_NAME=LaunchBusiness AI

# ── Stripe (required when billing goes live) ──────────────────────────────────
# dashboard.stripe.com → Developers → API keys
# Create 3 recurring products, paste the price IDs:
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=      # $19/month
STRIPE_PRO_PRICE_ID=          # $49/month
STRIPE_AGENCY_PRICE_ID=       # $149/month

# ── Modal GPU — Wan 2.2 video + SadTalker talking head (optional) ─────────────
# Required for GPU-accelerated AI video (Starter+) and talking head (Pro+).
# Without this: videos render with Pillow slides + Pexels footage only.
#
# Setup:
#   1. modal.com → Sign up → Settings → API Tokens → New Token
#   2. Paste below, then deploy:
#        modal deploy backend/modal_video.py
#        modal deploy backend/modal_sadtalker.py
#
# Cost: Wan 2.2 ~$0.03/clip (A10G) | SadTalker ~$0.10/video (A10G)
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
MODAL_APP_NAME=launchbusiness-wan-video
MODAL_SADTALKER_APP=launchbusiness-sadtalker

# ── Ideogram AI — logo AI concepts (optional) ────────────────────────────────
# ideogram.ai → API → Create token
# Without this the Logo Creator works with 6 Pillow templates only.
IDEOGRAM_API_KEY=

# ── Sentry — error tracking (optional) ───────────────────────────────────────
# sentry.io → Project → Settings → Client Keys (DSN)
SENTRY_DSN=
SENTRY_RELEASE=launchbusiness@1.0.0

# ── Runtime ───────────────────────────────────────────────────────────────────
ENVIRONMENT=production

# ── Server / Deployment ───────────────────────────────────────────────────────
SERVER_HOST=REPLACE_WITH_CONTABO_VPS_IP
DOMAIN=launchbusinessai.com

# ── Music Beds (background audio for videos) ──────────────────────────────────
# No env var needed — drop royalty-free .mp3 files into backend/assets/music_beds/
# Sources: pixabay.com/music | mixkit.co/free-music | ccmixter.org
# Empty folder = feature silently skipped (no error thrown)
