# SwiftPack AI — environment variable reference
# Copy to E:\secrets\swiftpack.env (local) or /home/ubuntu/secrets/swiftpack.env (server).
# Never fill in real values here — this file is committed to the repo.

# ── MongoDB ────────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017
DB_NAME=swiftpackai_db

# ── JWT & Admin ────────────────────────────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_32_CHARS
ADMIN_SECRET=REPLACE_WITH_STRONG_ADMIN_SECRET

# ── CORS & URLs ────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://swiftpackai.tech
BACKEND_URL=http://localhost:8001
FRONTEND_URL=http://localhost:3000

# ── Google OAuth ───────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=REPLACE_WITH_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=REPLACE_WITH_GOOGLE_CLIENT_SECRET

# ── Gemini AI ──────────────────────────────────────────────────────────────────
GEMINI_API_KEY=REPLACE_WITH_GEMINI_API_KEY
GOOGLE_APPLICATION_CREDENTIALS=/app/backend/gcloud-tts-key.json

# ── OpenRouter (Gemini fallback) ───────────────────────────────────────────────
OPENROUTER_API_KEY=

# ── Email (Brevo) ──────────────────────────────────────────────────────────────
BREVO_API_KEY=REPLACE_WITH_BREVO_API_KEY
BREVO_SENDER_EMAIL=noreply@swiftpackai.tech
BREVO_SENDER_NAME=SwiftPack AI

# ── Stripe ─────────────────────────────────────────────────────────────────────
# Free($0)/Starter($19)/Pro($49)/Agency($149) per month
STRIPE_SECRET_KEY=REPLACE_WITH_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=REPLACE_WITH_STRIPE_WEBHOOK_SECRET
STRIPE_STARTER_PRICE_ID=REPLACE_WITH_STRIPE_STARTER_PRICE_ID
STRIPE_PRO_PRICE_ID=REPLACE_WITH_STRIPE_PRO_PRICE_ID
STRIPE_AGENCY_PRICE_ID=REPLACE_WITH_STRIPE_AGENCY_PRICE_ID

# ── Modal GPU (Pro/Agency AI video — pay per second, $0 idle) ─────────────────
# Sign up: modal.com → Settings → API Tokens
# Deploy: modal deploy backend/modal_video.py && modal deploy backend/modal_sadtalker.py
# LTX-Video: ~$0.44/video on A100 | SadTalker: ~$0.10/video on A10G
MODAL_TOKEN_ID=REPLACE_WITH_MODAL_TOKEN_ID
MODAL_TOKEN_SECRET=REPLACE_WITH_MODAL_TOKEN_SECRET

# ── Music Beds (background music for videos) ──────────────────────────────────
# Drop royalty-free .mp3 files into backend/assets/music_beds/
# Free sources: pixabay.com/music or mixkit.co/free-music
# Leave folder empty = feature silently skipped (no error)

# ── Deployment ─────────────────────────────────────────────────────────────────
HETZNER_HOST=REPLACE_WITH_SERVER_IP
SERVER_USER=ubuntu
DOMAIN=swiftpackai.tech
