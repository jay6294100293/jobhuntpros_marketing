{
  "manifest_version": 3,
  "name": "LaunchBusiness AI — Tutorial Studio",
  "version": "1.0.0",
  "description": "Record your product demo and auto-generate a polished YouTube tutorial video.",

  "permissions": [
    "tabCapture",
    "activeTab",
    "storage"
  ],

  "host_permissions": [
    "https://launchbusinessai.com/*",
    "http://localhost:8001/*"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "LaunchBusiness AI — Tutorial Studio"
  },

  "background": {
    "service_worker": "background.js"
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
