# LaunchBusiness AI — Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy to /root/secrets/swiftpack.env (server) or backend/.env (local dev).
# NEVER commit a file containing real values.
# Generate secrets: python -c "import secrets; print(secrets.token_hex(32))"
# ─────────────────────────────────────────────────────────────────────────────

# ── MongoDB (REQUIRED) ────────────────────────────────────────────────────────
# Docker Compose uses service name "mongo" as hostname in production.
# Local dev: mongodb://localhost:27017
MONGODB_URL=mongodb://mongo:27017
DB_NAME=launchbusinessai_db

# ── CORS & URLs (REQUIRED) ───────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://launchbusinessai.com
FRONTEND_URL=https://launchbusinessai.com
BACKEND_URL=https://launchbusinessai.com

# ── JWT Auth (REQUIRED) ──────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET_MIN_32_CHARS

# ── Admin (REQUIRED) ─────────────────────────────────────────────────────────
# Used by JARVIS intelligence endpoint (GET /api/jarvis/pulse, X-Admin-Key header)
ADMIN_SECRET=REPLACE_WITH_STRONG_ADMIN_SECRET

# ── Google Gemini AI (REQUIRED) ──────────────────────────────────────────────
# Get from: aistudio.google.com → Get API key
# Used for: script generation, logo AI concepts, Tutorial Studio narration,
#           legal document generation, legal intake chat
GEMINI_API_KEY=REPLACE_WITH_GEMINI_API_KEY

# ── Google Safe Browsing (REQUIRED for URL safety) ───────────────────────────
# Blocks malware, phishing, and social engineering URLs before scraping.
# Free quota: 10,000 checks/day — enough for any launch volume.
#
# How to get it (5 minutes):
#   1. Go to console.cloud.google.com
#   2. Create a project (or use existing)
#   3. APIs & Services → Enable APIs → search "Safe Browsing API" → Enable
#   4. APIs & Services → Credentials → Create Credentials → API Key
#   5. Paste the key below
#
# If left blank: hostname + content checks still run, but phishing/malware
# sites with innocent-looking domain names won't be caught.
GOOGLE_SAFE_BROWSING_API_KEY=

# ── Pexels — real video B-roll (optional but recommended) ────────────────────
# Enables real stock video footage in the Magic Button video pipeline.
# Without this key: videos use Pillow design slides only (still looks good).
# With this key: real product-relevant video clips are mixed into output.
#
# How to get it (2 minutes, completely free):
#   1. Go to pexels.com/api
#   2. Sign up → your API key appears instantly on the dashboard
#   Free quota: 200 requests/hour, 20,000/month — no credit card needed.
PEXELS_API_KEY=

# ── AI Fallback chain (optional) ─────────────────────────────────────────────
# If Gemini fails, the pipeline tries OpenRouter first, then falls back to a
# built-in template. Leave blank to skip OpenRouter.
# Get from: openrouter.ai → Settings → API Keys
OPENROUTER_API_KEY=

# ── Google OAuth (optional — enables "Sign in with Google") ──────────────────
# console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client
# Add https://launchbusinessai.com/api/auth/google/callback as Redirect URI
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Stripe (required when billing goes live) ──────────────────────────────────
# dashboard.stripe.com → Developers → API keys
# Create 3 recurring products in Stripe Dashboard, copy the price IDs here:
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=      # $19/month
STRIPE_PRO_PRICE_ID=          # $49/month
STRIPE_AGENCY_PRICE_ID=       # $149/month

# ── Brevo — transactional email (optional) ───────────────────────────────────
# Used for: password reset emails, welcome emails
# app.brevo.com → SMTP & API → API Keys
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply@launchbusinessai.com
BREVO_SENDER_NAME=LaunchBusiness AI

# ── Modal GPU — Wan 2.2 video + SadTalker talking head (optional) ─────────────
# Required for: GPU-accelerated AI video (Starter+), talking head (Pro+)
# Without this: videos still render with Pillow slides + Pexels footage
#
# How to get it:
#   1. modal.com → Sign up → Settings → API Tokens → New Token
#   2. Paste MODAL_TOKEN_ID and MODAL_TOKEN_SECRET below
#   3. Deploy the apps once (run from server or local):
#        modal deploy backend/modal_video.py
#        modal deploy backend/modal_sadtalker.py
#
# Cost: Wan 2.2 ~$0.03/clip on A10G | SadTalker ~$0.10/video on A10G
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
MODAL_APP_NAME=launchbusiness-wan-video
MODAL_SADTALKER_APP=launchbusiness-sadtalker

# ── Ideogram AI — logo AI concepts (optional) ────────────────────────────────
# Without this: Logo Creator works with 6 Pillow templates (still useful).
# With this: "AI Concepts" tab generates Ideogram AI logo concepts.
# ideogram.ai → API → Create token
IDEOGRAM_API_KEY=

# ── Helicone — AI cost + latency tracking (optional) ─────────────────────────
# Routes all Gemini calls through Helicone for cost/latency dashboards.
# helicone.ai → Settings → API Keys
HELICONE_API_KEY=
HELICONE_HOST=https://gateway.helicone.ai

# ── Sentry — error tracking (optional) ───────────────────────────────────────
# sentry.io → Project → Settings → Client Keys (DSN)
SENTRY_DSN=
SENTRY_RELEASE=launchbusiness@1.0.0

# ── Runtime ───────────────────────────────────────────────────────────────────
ENVIRONMENT=production
