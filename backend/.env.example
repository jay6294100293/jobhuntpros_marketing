# LaunchBusiness AI — Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy to /root/secrets/swiftpack.env (server) or backend/.env (local dev).
# NEVER commit a file containing real values.
# Generate secrets: python -c "import secrets; print(secrets.token_hex(32))"
# ─────────────────────────────────────────────────────────────────────────────

# ── MongoDB (REQUIRED) ────────────────────────────────────────────────────────
# Docker Compose uses service name "mongo" as hostname in production
MONGODB_URL=mongodb://mongo:27017
DB_NAME=launchbusinessai_db

# ── CORS & URLs (REQUIRED) ───────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://launchbusinessai.com
FRONTEND_URL=https://launchbusinessai.com
BACKEND_URL=https://launchbusinessai.com

# ── JWT Auth (REQUIRED) ──────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET_MIN_32_CHARS

# ── Admin (REQUIRED) ─────────────────────────────────────────────────────────
# Used by JARVIS intelligence endpoint (GET /api/jarvis/pulse, X-Admin-Key header)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_SECRET=REPLACE_WITH_STRONG_ADMIN_SECRET

# ── Google Gemini AI (REQUIRED) ──────────────────────────────────────────────
# Get from: aistudio.google.com → Get API key
GEMINI_API_KEY=REPLACE_WITH_GEMINI_API_KEY

# ── AI Fallback chain (optional) ─────────────────────────────────────────────
# If Gemini fails, the pipeline tries OpenRouter first, then falls back to a
# built-in template. Leave blank to skip a provider.
OPENROUTER_API_KEY=

# ── Google OAuth (optional — enables "Sign in with Google") ──────────────────
# console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client
# Add https://launchbusinessai.com/api/auth/google/callback as Redirect URI
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Stripe (optional — activate when billing goes live) ──────────────────────
# dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Create products in Stripe Dashboard, then copy the price IDs here:
#   Starter plan → $19/month
STRIPE_STARTER_PRICE_ID=
#   Pro plan → $49/month
STRIPE_PRO_PRICE_ID=
#   Agency plan → $149/month
STRIPE_AGENCY_PRICE_ID=

# ── Brevo — transactional email ───────────────────────────────────────────────
# app.brevo.com → SMTP & API → API Keys
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply@launchbusinessai.com
BREVO_SENDER_NAME=LaunchBusiness AI

# ── Modal GPU — Pro/Agency video + talking head (optional) ───────────────────
# modal.com → Settings → API Tokens
# Deploy apps once: modal deploy backend/modal_video.py
#                   modal deploy backend/modal_sadtalker.py
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
MODAL_APP_NAME=launchbusiness-ltx-video
MODAL_SADTALKER_APP=launchbusiness-sadtalker

# ── Ideogram AI — logo concepts (optional) ───────────────────────────────────
# ideogram.ai → API → Create token
# Without this key the Logo Creator still works with Pillow templates;
# only the "AI concepts" tab is disabled.
IDEOGRAM_API_KEY=

# ── Helicone — AI cost tracking (optional) ───────────────────────────────────
# helicone.ai → Settings → API Keys
# Routes all Gemini calls through Helicone gateway for cost/latency dashboards.
HELICONE_API_KEY=
HELICONE_HOST=https://gateway.helicone.ai

# ── Sentry — error tracking (optional) ───────────────────────────────────────
# sentry.io → Project → Settings → Client Keys (DSN)
SENTRY_DSN=
SENTRY_RELEASE=launchbusiness@1.0.0

# ── Runtime ───────────────────────────────────────────────────────────────────
# "production" | "development"
ENVIRONMENT=production
