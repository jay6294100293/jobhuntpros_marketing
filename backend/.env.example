MONGO_URL="mongodb://localhost:27017"
DB_NAME="jobhuntpro"
CORS_ORIGINS="http://localhost:3000"
GEMINI_API_KEY="your-gemini-key-from-aistudio.google.com"
GOOGLE_APPLICATION_CREDENTIALS=/app/backend/gcloud-tts-key.json

# Script generation fallback chain (Gemini → OpenRouter → template)
OPENROUTER_API_KEY=""

# Auth — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET="change-this-to-a-long-random-secret"
BACKEND_URL="https://api.yourdomain.com"
FRONTEND_URL="https://yourdomain.com"

# Google OAuth — https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRO_PRICE_ID=""

# Brevo — https://app.brevo.com → SMTP & API → API Keys
BREVO_API_KEY=""
BREVO_SENDER_EMAIL="noreply@yourdomain.com"
BREVO_SENDER_NAME="JobHuntPro Studio"
